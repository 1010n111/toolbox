<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="导入工具"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:textColor="#212121" />

        <!-- 文件预览 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="文件预览"
                    android:textSize="14sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/file_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="未选择文件"
                    android:textSize="16sp"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/manifest_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 工具信息表单 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="工具信息"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:textColor="#212121" />

        <!-- 图标颜色选择 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="图标颜色"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"
            android:textColor="#757575" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="20dp">

            <View
                android:id="@+id/color_red"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@drawable/circle_color"
                android:tag="#F44336" />

            <View
                android:id="@+id/color_orange"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@drawable/circle_color"
                android:tag="#FF9800" />

            <View
                android:id="@+id/color_yellow"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@drawable/circle_color"
                android:tag="#FFEB3B" />

            <View
                android:id="@+id/color_green"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@drawable/circle_color"
                android:tag="#4CAF50" />

            <View
                android:id="@+id/color_blue"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@drawable/circle_color"
                android:tag="#2196F3" />

            <View
                android:id="@+id/color_indigo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@drawable/circle_color"
                android:tag="#3F51B5" />

            <View
                android:id="@+id/color_purple"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@drawable/circle_color"
                android:tag="#9C27B0" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#1976D2"
            app:hintTextColor="#1976D2"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FAFAFA"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="1dp"
            app:boxStrokeErrorColor="#F44336">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_tool_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="工具 ID (自动生成)"
                android:inputType="text"
                android:maxLines="1"
                android:focusable="false"
                android:clickable="false"
                android:textColor="#999999" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#1976D2"
            app:hintTextColor="#1976D2"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FAFAFA"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="1dp"
            app:boxStrokeErrorColor="#F44336">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_tool_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="工具名称 *"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#1976D2"
            app:hintTextColor="#1976D2"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FAFAFA"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="1dp"
            app:boxStrokeErrorColor="#F44336">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_tool_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="版本号"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#1976D2"
            app:hintTextColor="#1976D2"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FAFAFA"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="1dp"
            app:boxStrokeErrorColor="#F44336">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_tool_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="作者"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="#1976D2"
            app:hintTextColor="#1976D2"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FAFAFA"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="1dp"
            app:boxStrokeErrorColor="#F44336">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_tool_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="描述"
                android:inputType="textMultiLine"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btn_import"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="导入"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1976D2"
            android:enabled="false" />

    </LinearLayout>
</ScrollView>
